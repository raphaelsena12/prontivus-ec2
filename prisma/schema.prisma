generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                           String                       @id @default(uuid())
  nome                         String
  cnpj                         String                       @unique
  email                        String
  telefone                     String?
  status                       StatusClinica                @default(ATIVA)
  planoId                      String
  tokensMensaisDisponiveis     Int
  tokensConsumidos             Int                          @default(0)
  telemedicineHabilitada       Boolean                      @default(false)
  dataContratacao              DateTime
  dataExpiracao                DateTime?
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
  stripeCustomerId             String?                      @unique
  stripeSubscriptionId         String?                      @unique
  cep                          String?
  endereco                     String?
  numero                       String?
  complemento                  String?
  bairro                       String?
  cidade                       String?
  estado                       String?
  pais                         String?                      @default("Brasil")
  logoUrl                      String?                      @map("logourl")
  site                         String?
  whatsappAccessToken          String?
  whatsappPhoneNumberId        String?
  codigoCnes                   String?
  whatsappContatoNumero        String?
  autorizacoesFechamentoCaixa  AutorizacaoFechamentoCaixa[]
  bloqueiosAgenda              BloqueioAgenda[]
  cidsCatalogo                 Cid[]
  consentimentosLGPD           ConsentimentoLGPD[]
  consultaCids                 ConsultaCid[]
  consultaExames               ConsultaExame[]
  consultaPrescricoes          ConsultaPrescricao[]
  consultas                    Consulta[]
  contasPagar                  ContaPagar[]
  contasReceber                ContaReceber[]
  documentosGerados            DocumentoGerado[]
  estoqueInsumos               EstoqueInsumo[]
  estoqueMedicamentos          EstoqueMedicamento[]
  exames                       Exame[]
  examesPacientes              ExamePaciente[]
  faturamentosConvenio         FaturamentoConvenio[]
  fluxoCaixa                   FluxoCaixa[]
  formasPagamento              FormaPagamento[]
  glosas                       Glosa[]
  gruposExames                 GrupoExame[]
  guiasTiss                    GuiaTiss[]
  guiaTissProcedimentos        GuiaTissProcedimento[]
  insumos                      Insumo[]
  listasEspera                 ListaEspera[]
  lotesTiss                    LoteTiss[]
  manipulados                  Manipulado[]
  medicamentos                 Medicamento[]
  medicosTelemedicina          MedicoTelemedicina[]
  medicos                      Medico[]
  medicosCertificadosDigitais  MedicoCertificadoDigital[]
  medicoDocumentos             MedicoDocumento[]
  medicosEscalasAgenda         MedicoEscalaAgenda[]         @relation("TenantToMedicoEscalaAgenda")
  medicosEscalasAgendaExcecoes MedicoEscalaAgendaExcecao[]  @relation("TenantToMedicoEscalaAgendaExcecao")
  mensagens                    Mensagem[]
  mensagensMedicoSecretaria    MensagemMedicoSecretaria[]   @relation("MensagensMedicoSecretaria")
  movimentacoesEstoque         MovimentacaoEstoque[]
  operadorasLegadas            Operadora[]                  @relation("TenantOperadorasLegadas")
  pacientes                    Paciente[]
  pagamentos                   Pagamento[]
  pagamentosConsultas          PagamentoConsulta[]
  prescricoesMedicamentos      PrescricaoMedicamento[]
  procedimentos                Procedimento[]
  prontuarios                  Prontuario[]
  recebimentosConvenio         RecebimentoConvenio[]
  retornosLotes                RetornoLote[]
  solicitacoesDSAR             SolicitacaoDSAR[]
  solicitacoesExames           SolicitacaoExame[]
  plano                        Plano                        @relation(fields: [planoId], references: [id])
  tenantOperadoras             TenantOperadora[]
  tussValores                  TussValor[]
  usuarios                     Usuario[]
  usuariosTenants              UsuarioTenant[]

  @@index([cnpj])
  @@index([dataExpiracao])
  @@index([status])
  @@index([stripeCustomerId])
  @@map("tenants")
}

model Plano {
  id                     String    @id @default(uuid())
  nome                   TipoPlano @unique
  tokensMensais          Int
  telemedicineHabilitada Boolean   @default(false)
  preco                  Decimal   @db.Decimal(10, 2)
  descricao              String?
  ativo                  Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  tenants                Tenant[]

  @@map("planos")
}

model Usuario {
  id                        String                     @id @default(uuid())
  email                     String                     @unique
  senha                     String
  nome                      String
  cpf                       String                     @unique
  telefone                  String?
  avatar                    String?
  tipo                      TipoUsuario
  clinicaId                 String?
  ativo                     Boolean                    @default(true)
  primeiroAcesso            Boolean                    @default(true)
  ultimoAcesso              DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  resetToken                String?
  resetTokenExpires         DateTime?
  isEnfermeiro              Boolean                    @default(false)
  cpfHash                   String?
  emailHash                 String?
  telefoneHash              String?
  medicos                   Medico[]
  mensagensMedicoSecretaria MensagemMedicoSecretaria[]
  pacientes                 Paciente[]
  sessoes                   Sessao[]
  clinica                   Tenant?                    @relation(fields: [clinicaId], references: [id])
  usuariosTenants           UsuarioTenant[]

  @@index([email])
  @@index([emailHash])
  @@index([cpfHash])
  @@index([telefoneHash])
  @@index([clinicaId])
  @@index([resetToken])
  @@map("usuarios")
}

model Sessao {
  id        String   @id @default(uuid())
  usuarioId String
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("sessoes")
}

model UsuarioTenant {
  id        String      @id @default(uuid())
  usuarioId String
  tenantId  String
  tipo      TipoUsuario
  ativo     Boolean     @default(true)
  isPrimary Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario   Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, tenantId])
  @@index([usuarioId])
  @@index([tenantId])
  @@index([tipo])
  @@map("usuarios_tenants")
}

model Pagamento {
  id              String          @id @default(uuid())
  tenantId        String
  valor           Decimal         @db.Decimal(10, 2)
  mesReferencia   DateTime
  status          StatusPagamento @default(PENDENTE)
  metodoPagamento String?
  transacaoId     String?
  dataPagamento   DateTime?
  dataVencimento  DateTime
  observacoes     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([mesReferencia])
  @@index([dataVencimento])
  @@map("pagamentos")
}

model Paciente {
  id                  String              @id @default(uuid())
  clinicaId           String
  nome                String
  cpf                 String
  rg                  String?
  dataNascimento      DateTime
  sexo                String
  email               String?
  telefone            String?
  celular             String?
  cep                 String?
  endereco            String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  estado              String?
  nomeMae             String?
  nomePai             String?
  profissao           String?
  estadoCivil         String?
  observacoes         String?
  ativo               Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  usuarioId           String?
  numeroProntuario    Int?                @unique
  cns                 String?
  numeroCarteirinha   String?
  celularHash         String?
  cpfHash             String?
  emailHash           String?
  telefoneHash        String?
  consentimentos      ConsentimentoLGPD[]
  consultas           Consulta[]
  contasReceber       ContaReceber[]
  examesPaciente      ExamePaciente[]
  guiasTiss           GuiaTiss[]
  listasEspera        ListaEspera[]
  mensagens           Mensagem[]
  clinica             Tenant              @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  usuario             Usuario?            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pacientesPlanos     PacientePlano[]
  pagamentosConsultas PagamentoConsulta[]
  prontuarios         Prontuario[]
  solicitacoesDSAR    SolicitacaoDSAR[]

  @@unique([clinicaId, usuarioId])
  @@index([clinicaId])
  @@index([cpf])
  @@index([cpfHash])
  @@index([emailHash])
  @@index([telefoneHash])
  @@index([celularHash])
  @@index([nome])
  @@index([usuarioId])
  @@index([numeroProntuario])
  @@map("pacientes")
}

model Medico {
  id                          String                       @id @default(uuid())
  clinicaId                   String
  usuarioId                   String
  crm                         String
  especialidade               String
  ativo                       Boolean                      @default(true)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  limiteMaximoRetornosPorDia  Int?
  rqe                         Int?
  ufCrm                       String                       @default("")
  codigoCbo                   String                       @default("")
  autorizacoesFechamentoCaixa AutorizacaoFechamentoCaixa[]
  bloqueiosAgenda             BloqueioAgenda[]
  consultas                   Consulta[]
  documentos                  DocumentoGerado[]
  gruposExames                GrupoExame[]
  guiasTiss                   GuiaTiss[]
  listasEspera                ListaEspera[]
  manipulados                 Manipulado[]
  telemedicina                MedicoTelemedicina?
  clinica                     Tenant                       @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  usuario                     Usuario                      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  certificadoDigital          MedicoCertificadoDigital?
  medicoDocumentos            MedicoDocumento[]
  escalasAgenda               MedicoEscalaAgenda[]
  excecoesEscalaAgenda        MedicoEscalaAgendaExcecao[]
  medicoEspecialidades        MedicoEspecialidade[]
  mensagens                   Mensagem[]
  mensagensMedicoSecretaria   MensagemMedicoSecretaria[]
  prontuarios                 Prontuario[]

  @@unique([clinicaId, usuarioId])
  @@index([clinicaId])
  @@index([crm])
  @@index([usuarioId])
  @@map("medicos")
}

model MedicoEscalaAgenda {
  id         String   @id @default(uuid())
  clinicaId  String
  medicoId   String
  diaSemana  Int
  horaInicio String
  horaFim    String
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  clinica    Tenant   @relation("TenantToMedicoEscalaAgenda", fields: [clinicaId], references: [id], onDelete: Cascade)
  medico     Medico   @relation(fields: [medicoId], references: [id], onDelete: Cascade)

  @@index([clinicaId, medicoId, diaSemana])
  @@index([medicoId, ativo])
  @@map("medicos_escalas_agenda")
}

model MedicoEscalaAgendaExcecao {
  id          String   @id @default(uuid())
  clinicaId   String
  medicoId    String
  data        DateTime
  horaInicio  String?
  horaFim     String?
  ativo       Boolean  @default(false)
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clinica     Tenant   @relation("TenantToMedicoEscalaAgendaExcecao", fields: [clinicaId], references: [id], onDelete: Cascade)
  medico      Medico   @relation(fields: [medicoId], references: [id], onDelete: Cascade)

  @@index([clinicaId, medicoId, data])
  @@index([medicoId, data])
  @@map("medicos_escalas_agenda_excecoes")
}

model MedicoTelemedicina {
  id               String    @id @default(uuid())
  medicoId         String    @unique
  clinicaId        String
  status           String    @default("OFFLINE")
  inicioImediato   Boolean   @default(true)
  horaInicio       String?
  horaFim          String?
  diasSemana       String[]  @default(["SEG", "TER", "QUA", "QUI", "SEX"])
  valorConsulta    Decimal   @default(0) @db.Decimal(10, 2)
  tempoConsultaMin Int       @default(30)
  bio              String?
  tags             String[]  @default([])
  fotoUrl          String?
  onlineSince      DateTime?
  updatedAt        DateTime  @updatedAt
  clinica          Tenant    @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  medico           Medico    @relation(fields: [medicoId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([clinicaId])
  @@map("medico_telemedicina")
}

model MedicoCertificadoDigital {
  id           String    @id @default(uuid())
  clinicaId    String
  medicoId     String    @unique
  pfxS3Key     String
  pfxMimeType  String
  pfxTamanho   Int
  senhaEnc     String
  validTo      DateTime?
  subject      String?
  issuer       String?
  serialNumber String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  clinica      Tenant    @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  medico       Medico    @relation(fields: [medicoId], references: [id], onDelete: Cascade)

  @@index([clinicaId])
  @@map("medicos_certificados_digitais")
}

model Exame {
  id                 String             @id @default(uuid())
  clinicaId          String
  nome               String
  descricao          String?
  tipo               String?
  ativo              Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  codigoTussId       String?
  clinica            Tenant             @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  codigoTuss         CodigoTuss?        @relation(fields: [codigoTussId], references: [id])
  gruposExames       GrupoExameItem[]
  solicitacoesExames SolicitacaoExame[]

  @@index([clinicaId])
  @@index([nome])
  @@index([codigoTussId])
  @@map("exames")
}

model Medicamento {
  id                        String                    @id @default(uuid())
  clinicaId                 String?
  nome                      String
  principioAtivo            String?
  laboratorio               String?
  apresentacao              String?
  concentracao              String?
  unidade                   String?
  ativo                     Boolean                   @default(true)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  numeroRegistro            String?
  controle                  String?
  pharmaceuticalForm        String?
  therapeuticClass          String?
  prescriptionType          String?
  controlType               String?
  pregnancyRisk             Boolean                   @default(false)
  pediatricUse              Boolean                   @default(false)
  hepaticAlert              Boolean                   @default(false)
  renalAlert                Boolean                   @default(false)
  highRisk                  Boolean                   @default(false)
  status                    String                    @default("active")
  estoqueMedicamentos       EstoqueMedicamento[]
  clinica                   Tenant?                   @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  prescricoesMedicamentos   PrescricaoMedicamento[]
  procedimentosMedicamentos ProcedimentoMedicamento[]

  @@unique([clinicaId, numeroRegistro])
  @@index([clinicaId])
  @@index([nome])
  @@index([numeroRegistro])
  @@map("medicamentos")
}

model MedicamentoAnvisa {
  id                String   @id @default(uuid())
  numeroRegistro    String   @unique
  nomeProduto       String
  principioAtivo    String?
  empresa           String?
  situacaoRegistro  String?
  classeTerapeutica String?
  apresentacao      String?
  concentracao      String?
  data              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([numeroRegistro])
  @@index([nomeProduto])
  @@index([principioAtivo])
  @@index([empresa])
  @@map("medicamentos_anvisa")
}

model Insumo {
  id                   String               @id @default(uuid())
  clinicaId            String
  nome                 String
  descricao            String?
  unidade              String?
  ativo                Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  estoqueInsumo        EstoqueInsumo?
  clinica              Tenant               @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  procedimentosInsumos ProcedimentoInsumo[]

  @@index([clinicaId])
  @@index([nome])
  @@map("insumos")
}

model Procedimento {
  id                        String                    @id @default(uuid())
  clinicaId                 String
  codigo                    String
  nome                      String
  descricao                 String?
  valor                     Decimal                   @db.Decimal(10, 2)
  ativo                     Boolean                   @default(true)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  consultas                 Consulta[]
  clinica                   Tenant                    @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  procedimentosInsumos      ProcedimentoInsumo[]
  procedimentosMedicamentos ProcedimentoMedicamento[]

  @@index([clinicaId])
  @@index([codigo])
  @@map("procedimentos")
}

model ProcedimentoMedicamento {
  id             String       @id @default(uuid())
  procedimentoId String
  medicamentoId  String
  quantidade     Decimal?     @db.Decimal(10, 2)
  observacoes    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  medicamento    Medicamento  @relation(fields: [medicamentoId], references: [id], onDelete: Cascade)
  procedimento   Procedimento @relation(fields: [procedimentoId], references: [id], onDelete: Cascade)

  @@unique([procedimentoId, medicamentoId])
  @@index([procedimentoId])
  @@index([medicamentoId])
  @@map("procedimentos_medicamentos")
}

model ProcedimentoInsumo {
  id             String       @id @default(uuid())
  procedimentoId String
  insumoId       String
  quantidade     Decimal?     @db.Decimal(10, 2)
  observacoes    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  insumo         Insumo       @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  procedimento   Procedimento @relation(fields: [procedimentoId], references: [id], onDelete: Cascade)

  @@unique([procedimentoId, insumoId])
  @@index([procedimentoId])
  @@index([insumoId])
  @@map("procedimentos_insumos")
}

model FormaPagamento {
  id             String         @id @default(uuid())
  clinicaId      String?
  nome           String
  descricao      String?
  tipo           String
  ativo          Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  bandeiraCartao String?
  consultas      Consulta[]
  contasReceber  ContaReceber[]
  fluxoCaixa     FluxoCaixa[]
  clinica        Tenant?        @relation(fields: [clinicaId], references: [id], onDelete: Cascade)

  @@index([clinicaId])
  @@index([nome])
  @@map("formas_pagamento")
}

model ContaPagar {
  id               String    @id @default(uuid())
  clinicaId        String
  descricao        String
  fornecedor       String?
  valor            Decimal   @db.Decimal(10, 2)
  dataVencimento   DateTime
  dataPagamento    DateTime?
  status           String    @default("PENDENTE")
  formaPagamentoId String?
  observacoes      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  clinica          Tenant    @relation(fields: [clinicaId], references: [id], onDelete: Cascade)

  @@index([clinicaId])
  @@index([dataVencimento])
  @@index([status])
  @@map("contas_pagar")
}

model ContaReceber {
  id               String          @id @default(uuid())
  clinicaId        String
  descricao        String
  pacienteId       String?
  valor            Decimal         @db.Decimal(10, 2)
  dataVencimento   DateTime
  dataRecebimento  DateTime?
  status           String          @default("PENDENTE")
  formaPagamentoId String?
  observacoes      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  clinica          Tenant          @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  formaPagamento   FormaPagamento? @relation(fields: [formaPagamentoId], references: [id])
  paciente         Paciente?       @relation(fields: [pacienteId], references: [id])

  @@index([clinicaId])
  @@index([dataVencimento])
  @@index([status])
  @@map("contas_receber")
}

model FluxoCaixa {
  id               String          @id @default(uuid())
  clinicaId        String
  tipo             String
  descricao        String
  valor            Decimal         @db.Decimal(10, 2)
  data             DateTime
  formaPagamentoId String?
  observacoes      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  clinica          Tenant          @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  formaPagamento   FormaPagamento? @relation(fields: [formaPagamentoId], references: [id])

  @@index([clinicaId])
  @@index([tipo])
  @@index([data])
  @@map("fluxo_caixa")
}

model EstoqueMedicamento {
  id                   String                @id @default(uuid())
  clinicaId            String
  medicamentoId        String
  quantidadeAtual      Int                   @default(0)
  quantidadeMinima     Int                   @default(0)
  quantidadeMaxima     Int?
  unidade              String                @default("UN")
  localizacao          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  clinica              Tenant                @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  medicamento          Medicamento           @relation(fields: [medicamentoId], references: [id], onDelete: Cascade)
  movimentacoesEstoque MovimentacaoEstoque[]

  @@index([clinicaId])
  @@index([medicamentoId])
  @@map("estoque_medicamentos")
}

model EstoqueInsumo {
  id                   String                @id @default(uuid())
  clinicaId            String
  insumoId             String                @unique
  quantidadeAtual      Int                   @default(0)
  quantidadeMinima     Int                   @default(0)
  quantidadeMaxima     Int?
  unidade              String                @default("UN")
  localizacao          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  clinica              Tenant                @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  insumo               Insumo                @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  movimentacoesEstoque MovimentacaoEstoque[]

  @@index([clinicaId])
  @@index([insumoId])
  @@map("estoque_insumos")
}

model MovimentacaoEstoque {
  id                   String              @id @default(uuid())
  clinicaId            String
  tipo                 String
  quantidade           Int
  motivo               String?
  observacoes          String?
  data                 DateTime            @default(now())
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  estoqueMedicamentoId String?
  estoqueInsumoId      String?
  tipoEstoque          String
  clinica              Tenant              @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  estoqueInsumo        EstoqueInsumo?      @relation(fields: [estoqueInsumoId], references: [id], onDelete: Cascade)
  estoqueMedicamento   EstoqueMedicamento? @relation(fields: [estoqueMedicamentoId], references: [id], onDelete: Cascade)

  @@index([clinicaId])
  @@index([estoqueMedicamentoId])
  @@index([estoqueInsumoId])
  @@index([tipo])
  @@index([tipoEstoque])
  @@index([data])
  @@map("movimentacoes_estoque")
}

model Consulta {
  id                      String                  @id @default(uuid())
  clinicaId               String
  pacienteId              String
  medicoId                String
  dataHora                DateTime
  status                  String                  @default("AGENDADA")
  observacoes             String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  codigoTussId            String?
  dataAutorizacao         DateTime?
  numeroAutorizacao       String?
  numeroCarteirinha       String?
  operadoraId             String?
  planoSaudeId            String?
  preparadoTiss           Boolean                 @default(false)
  tipoConsultaId          String?
  valorCobrado            Decimal?                @db.Decimal(10, 2)
  valorRepassado          Decimal?                @db.Decimal(10, 2)
  procedimentoId          String?
  inicioAtendimento       DateTime?
