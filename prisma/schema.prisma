  // clinicaId:
  // - NULL   => operadora global (catálogo gerenciado pelo SUPER_ADMIN)
  // - filled => operadora legada/criada por clínica (mantida por compatibilidade)
  clinicaId    String?
  codigoAns    String
  razaoSocial  String
  nomeFantasia String?
  cnpj         String?
  telefone     String?
  email        String?
  cep          String?
  endereco     String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?
  pais         String?  @default("Brasil")
