  consultas      Consulta[]
  planosSaude    PlanoSaude[]
  tussOperadoras TussOperadora[]
  tussValores    TussValor[]
  guiasTiss              GuiaTiss[]
  lotesTiss              LoteTiss[]
  retornosLotes          RetornoLote[]
  recebimentosConvenio   RecebimentoConvenio[]
  faturamentosConvenio   FaturamentoConvenio[]

  @@index([clinicaId])
  @@index([codigoAns])
  @@index([cnpj])
  @@index([ativo])
  @@map("operadoras")
}

