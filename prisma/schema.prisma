  @@index([subgrupoTuss])
  @@index([grupoTuss])
  @@index([capituloTuss])
  @@index([grupoId])
  @@index([dataVigenciaInicio, dataVigenciaFim])
  @@index([ativo])
  @@map("codigos_tuss")
}

