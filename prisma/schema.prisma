  valorRecebido   Decimal   @db.Decimal(10, 2)
  dataRecebimento DateTime
  dataPrevista    DateTime?
  numeroDocumento String?
  metodoPagamento String?
  observacoes     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clinica   Tenant     @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  operadora Operadora  @relation(fields: [operadoraId], references: [id])
  lote      LoteTiss?  @relation(fields: [loteId], references: [id])

  @@index([clinicaId])
  @@index([operadoraId])
  @@index([loteId])
  @@index([dataRecebimento])
  @@map("recebimentos_convenio")
}

// =====================================================================
// FATURAMENTO MENSAL POR CONVÊNIO
// =====================================================================
model FaturamentoConvenio {
  id             String   @id @default(uuid())
  clinicaId      String
  operadoraId    String
  mesReferencia  DateTime
  valorFaturado  Decimal  @db.Decimal(10, 2) @default(0)
  valorRecebido  Decimal  @db.Decimal(10, 2) @default(0)
  valorGlosado   Decimal  @db.Decimal(10, 2) @default(0)
  status         String   @default("ABERTO") // ABERTO, FECHADO, CONCILIADO
  observacoes    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinica   Tenant    @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  operadora Operadora @relation(fields: [operadoraId], references: [id])

  @@unique([clinicaId, operadoraId, mesReferencia])
  @@index([clinicaId])
  @@index([operadoraId])
  @@index([mesReferencia])
  @@index([status])
  @@map("faturamentos_convenio")
}

model Mensagem {
