model AutorizacaoFechamentoCaixa {
  id                   String    @id @default(uuid())
  clinicaId            String
  medicoId             String
  data                 DateTime // Data do fechamento
  autorizadoEm         DateTime  @default(now())
  fechadoEm            DateTime?
  status               String    @default("AUTORIZADO") // "AUTORIZADO", "FECHADO", "CANCELADO"
  observacoes          String?
  assinaturaMedico     String? // Base64 da assinatura do médico
  assinaturaSecretaria String? // Base64 da assinatura da secretária
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  clinica Tenant @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  medico  Medico @relation(fields: [medicoId], references: [id], onDelete: Cascade)

  @@unique([clinicaId, medicoId, data])
  @@index([clinicaId])
  @@index([medicoId])
  @@index([data])
  @@index([status])
  @@map("autorizacoes_fechamento_caixa")
}

// ─── Telemedicina ────────────────────────────────────────────────────────────

model TelemedicineSession {
  id                    String    @id @default(uuid())
  consultaId            String    @unique
  meetingId             String?   // AWS Chime Meeting ID
  meetingData           Json?     // Resposta completa do CreateMeeting (para join)
  status                String    @default("scheduled") // scheduled|waiting|in_progress|finished|cancelled
  patientToken          String    @unique              // Token do link público do paciente
  patientTokenExpiresAt DateTime
  identityVerifiedAt    DateTime? // Preenchido após validação do CPF
  createdAt             DateTime  @default(now())
  startedAt             DateTime?
  finishedAt            DateTime?

  consulta     Consulta                  @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  participants TelemedicineParticipant[]
  logs         TelemedicineLog[]
  consents     TelemedicineConsent[]

  @@index([patientToken])
  @@index([status])
  @@map("telemedicine_sessions")
}

model TelemedicineParticipant {
  id           String    @id @default(uuid())
  sessionId    String
  pacienteId   String?
  medicoId     String?
  role         String    // DOCTOR | PATIENT
  attendeeId   String?   // AWS Chime Attendee ID
  attendeeData Json?     // Resposta completa do CreateAttendee
  joinTime     DateTime?
  leaveTime    DateTime?

  session TelemedicineSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([role])
  @@map("telemedicine_participants")
}

model TelemedicineLog {
  id         String   @id @default(uuid())
  sessionId  String
  pacienteId String?
  medicoId   String?
  role       String?  // DOCTOR | PATIENT
  eventType  String   // SESSION_CREATED | PATIENT_LINK_SENT | IDENTITY_VERIFIED | IDENTITY_FAILED | CONSENT_GIVEN | PATIENT_JOINED | DOCTOR_JOINED | SESSION_STARTED | SESSION_ENDED | DISCONNECT
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  session TelemedicineSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([eventType])
  @@map("telemedicine_logs")
}

model TelemedicineConsent {
  id               String   @id @default(uuid())
  sessionId        String
  pacienteId       String
  consentGiven     Boolean  @default(false)
  consentVersion   String   @default("1.0")
  ipAddress        String?
  userAgent        String?
  consentTimestamp DateTime @default(now())

  session TelemedicineSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@map("telemedicine_consents")
}

// =====================================================
// CONSULTA — DADOS CLÍNICOS PERSISTIDOS
// =====================================================

model ConsultaCid {
  id          String   @id @default(uuid())
  clinicaId   String
  consultaId  String
  code        String
  description String
  createdAt   DateTime @default(now())

  clinica  Tenant   @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  consulta Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)

  @@index([clinicaId])
  @@index([consultaId])
  @@map("consulta_cids")
}

model Cid {
  id           String   @id @default(uuid())
  clinicaId    String?
  codigo       String
  descricao    String
  // Campos "estruturados" (conforme layout do Excel: grupo/categoria/subcategoria)
  // Mantemos `codigo`/`descricao` por compatibilidade (ex.: busca/seleção em atendimento),
  // tipicamente mapeando para `subcategoriaCod`/`subcategoriaNome`.
  grupoNome       String?
  categoriaCod    String?
  categoriaNome   String?
  subcategoriaCod String?
  subcategoriaNome String?
  categoria    String?
  subcategoria String?
  observacoes  String?
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinica Tenant? @relation(fields: [clinicaId], references: [id], onDelete: Cascade)

  @@unique([clinicaId, codigo])
  @@index([clinicaId])
  @@index([codigo])
  @@index([descricao])
  @@index([ativo])
  @@map("cids")
}

model ConsultaExame {
  id         String   @id @default(uuid())
  clinicaId  String
  consultaId String
  nome       String
  tipo       String?
  createdAt  DateTime @default(now())

  clinica  Tenant   @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  consulta Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)

  @@index([clinicaId])
  @@index([consultaId])
  @@map("consulta_exames")
}

model ConsultaPrescricao {
  id          String   @id @default(uuid())
  clinicaId   String
  consultaId  String
  medicamento String
  dosagem     String?
  posologia   String
  duracao     String?
  createdAt   DateTime @default(now())

  clinica  Tenant   @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  consulta Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)

  @@index([clinicaId])
  @@index([consultaId])
  @@map("consulta_prescricoes")
}
