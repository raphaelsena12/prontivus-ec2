  loteId           String?
  operadoraId      String
  numeroProtocolo  String?
  dataRecebimento  DateTime  @default(now())
  xmlRetorno       String?   @db.Text
  status           String    @default("RECEBIDO") // RECEBIDO, PROCESSADO
  observacoes      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  clinica   Tenant     @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  lote      LoteTiss?  @relation(fields: [loteId], references: [id])
  operadora Operadora  @relation(fields: [operadoraId], references: [id])
  glosas    Glosa[]

  @@index([clinicaId])
  @@index([loteId])
  @@index([operadoraId])
  @@index([status])
  @@map("retornos_lotes")
}

// =====================================================================
// GLOSA (negativa/contestação de procedimento)
// =====================================================================
model Glosa {
  id                       String    @id @default(uuid())
  clinicaId                String
  guiaId                   String
  procedimentoId           String?
  retornoLoteId            String?
  codigoGlosa              String?   // Código da glosa TISS
  descricaoGlosa           String?
  valorGlosado             Decimal   @db.Decimal(10, 2)
  status                   String    @default("GLOSADA") // GLOSADA, CONTESTADA, ACEITA, REVERTIDA, MANTIDA
  justificativaContestacao String?   @db.Text
  dataGlosa                DateTime  @default(now())
  dataContestacao          DateTime?
  dataResolucao            DateTime?
  observacoes              String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  clinica      Tenant                @relation(fields: [clinicaId], references: [id], onDelete: Cascade)
  guia         GuiaTiss              @relation(fields: [guiaId], references: [id])
  procedimento GuiaTissProcedimento? @relation(fields: [procedimentoId], references: [id])
  retornoLote  RetornoLote?          @relation(fields: [retornoLoteId], references: [id])

  @@index([clinicaId])
  @@index([guiaId])
  @@index([procedimentoId])
  @@index([retornoLoteId])
  @@index([status])
  @@map("glosas")
}

// =====================================================================
// RECEBIMENTO DE CONVÊNIO (pagamento da operadora)
// =====================================================================
